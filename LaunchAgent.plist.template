<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.heypanda.cc-dashboard</string>
    <key>ProgramArguments</key>
    <array>
        <string>__APP_PATH__/Contents/MacOS/CCDashboard</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/cc-dashboard.out.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/cc-dashboard.err.log</string>
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
